# Dependencies & build output
node_modules/
dist/
*.tgz

# Logs
*.log

# OS cruft
.DS_Store

# Environment files — NEVER commit real env, only the placeholder template
.env
.env.*
!.env.example

# Secrets / signing keys — never commit
*.pem
*.hex
*.key
*privkey*

# Private list of sensitive terms the tarball guard enforces (never published)
.forbidden-terms
