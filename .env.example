# ── stdio (npm package) ───────────────────────────────────────────────
# Get your API key from https://app.dragapp.com → Settings → Integrations
DRAG_API_KEY=your-api-key-here

# ── HTTP entry point (hosted remote endpoint) ─────────────────────────
# The HTTP server reads the DragApp token per-request from the Authorization
# header, so DRAG_API_KEY is NOT used here. See DEPLOY.md for details.

# Port the HTTP server listens on (default 3001).
MCP_PORT=3001
# Path the MCP handler answers on. "/" is always accepted too, so this works
# whether NGINX strips the /mcp prefix or passes it through (default /mcp).
MCP_PATH=/mcp
# DragApp API base URL. Defaults to the public edge; point at an internal VPC
# address to avoid hairpinning through the public edge.
DRAG_API_BASE=https://app.dragapp.com

# ── Rate limiting (Redis) ─────────────────────────────────────────────
# If REDIS_HOST is unset, rate limiting is disabled (all requests allowed).
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
# Max requests per window, per token (deploy-time decision).
MCP_RATE_LIMIT=60
# Window length in seconds.
MCP_RATE_WINDOW=60
# On a Redis outage: "true" allows requests (fail-open, default), "false" blocks.
MCP_RATE_LIMIT_FAIL_OPEN=true
